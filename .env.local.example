NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
RESEND_API_KEY=
RESEND_FROM_EMAIL=
ANTHROPIC_API_KEY=
BRAND_AGENCY_ID=
REVIEWER_MODEL=claude-sonnet-4-6
ADMIN_EMAILS=brook@yourpolicyplace.com,wesoverstreet@gmail.com

# Optional audit BCC/CC on every sent certificate. Cert Holders see this address
# in the email envelope, so use an inbox that's safe to expose (or leave unset).
COI_CC_AUDIT_EMAIL=

# HMAC secret for one-tap admin approval tokens embedded in queue-notification
# emails. Must be 32+ hex chars. Generate with `openssl rand -hex 32`.
# Rotating this secret invalidates every outstanding approval link.
APPROVAL_TOKEN_SECRET=

# Inbound email → auto-COI (POST /api/inbound/coi-request)
# Shared secret sent from the inbound provider (Resend Inbound / Postmark / SES) as
# `x-inbound-secret` (or `x-webhook-secret`). Generate with `openssl rand -hex 32`.
RESEND_INBOUND_WEBHOOK_SECRET=
# Public address clients email their requests to. Configure this in Resend Inbound.
INBOUND_COI_ADDRESS=coi@inbound.policyplace.com
# Override the Claude model used by the inbound classifier + parser (optional).
INBOUND_LLM_MODEL=claude-sonnet-4-6
